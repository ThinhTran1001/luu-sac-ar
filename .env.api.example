# API Service Environment Variables (Render)

NODE_ENV=production
PORT=10000

# Database - Use Neon PostgreSQL connection string
# Get from: https://console.neon.tech/app/projects
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxxxx.region.aws.neon.tech/dbname?sslmode=require

# JWT Secret (Generate with: openssl rand -base64 32)
JWT_SECRET=your-super-secret-jwt-key-change-this

# CORS - Set to your Web service URL on Render
# Example: https://luu-sac-web.onrender.com
CORS_ORIGIN=https://your-web-app.onrender.com

# Cloudinary Configuration (Get from: https://cloudinary.com/console)
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# PayOS Payment Gateway (Get from: https://my.payos.vn)
PAYOS_CLIENT_ID=your-payos-client-id
PAYOS_API_KEY=your-payos-api-key
PAYOS_CHECKSUM_KEY=your-payos-checksum-key

# 3D AI Studio API Key (Get from: https://www.3daistudio.com/Platform/API#api-keys)
AI3D_STUDIO_API_KEY=your-3d-ai-studio-api-key

# Mock 3D generation (set "true" to test the full async flow without using real API tokens)
# Simulates a ~20s generation pipeline with a sample GLB URL
MOCK_3D_GENERATION=false
