# Web Service Environment Variables (Render)

NODE_ENV=production

# API Backend URL - Set to your API service URL on Render
# Example: https://luu-sac-api.onrender.com
NEXT_PUBLIC_API_URL=https://your-api.onrender.com

# API Backend URL is used for 3D generation proxy (3D AI Studio)
# No separate 3D service URL needed - calls go through the backend API
